# ── Exhibitor Extractor — Backend Environment Variables ───────────────────────
# Copy this file to .env for local development (never commit .env)

# Server
PORT=3001
NODE_ENV=development

# Database — where to store the SQLite file.
# Local dev: leave empty (uses backend/ folder)
# Railway production: set to /data (mount a Railway Volume at /data)
DATA_DIR=

# CORS — comma-separated list of allowed frontend origins.
# Local dev: http://localhost:5173
# Production (same Railway service): * or leave empty — same-origin requests need no CORS
# Production (separate Vercel frontend): https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Chromium — path to system Chromium binary.
# Leave empty in local dev (Playwright uses its bundled browser).
# Railway/Docker: /usr/bin/chromium  (set automatically via Dockerfile ENV)
CHROMIUM_PATH=

# Optional enrichment API keys (used by the Enrich Websites feature)
# Get a free key at https://hunter.io
HUNTER_API_KEY=
# Get a free key at https://app.clearbit.com
CLEARBIT_API_KEY=
# Google Custom Search (for website enrichment fallback)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
