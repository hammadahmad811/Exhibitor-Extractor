# ── Dependencies ───────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
backend/node_modules/

# ── Build output ────────────────────────────────────────────────────────────────
frontend/dist/
frontend/build/

# ── SQLite database files (use Railway volume in production) ───────────────────
*.db
*.db-shm
*.db-wal

# ── Runtime data (legacy JSON history) ────────────────────────────────────────
backend/data/history.json
backend/data/.migrated

# ── Environment variables ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local

# ── Playwright browser cache ───────────────────────────────────────────────────
playwright-report/
test-results/
.playwright/

# ── OS / Editor ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/settings.json
.idea/

# ── Windows launch scripts (not needed in CI/production) ──────────────────────
*.bat
*.ps1

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
