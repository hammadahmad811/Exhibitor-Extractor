# ── Exhibitor Extractor — Frontend Environment Variables ──────────────────────
# Copy this file to .env.local for local development (never commit .env.local)
# Vite only exposes variables prefixed with VITE_ to the browser.

# Backend API URL — only needed if the frontend is deployed separately from
# the backend (e.g. frontend on Vercel, backend on Railway).
#
# Leave EMPTY when running locally with the Vite dev server (it proxies /api
# to localhost:3001 automatically).
#
# When deploying frontend separately, set this to your Railway backend URL:
# VITE_API_URL=https://your-app.railway.app
VITE_API_URL=
