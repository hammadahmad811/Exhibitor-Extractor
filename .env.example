# ── Root-level env example ────────────────────────────────────────────────────
# These are the Railway service-level environment variables.
# Set them in Railway Dashboard → your service → Variables tab.

NODE_ENV=production
PORT=3001

# Path where SQLite database is stored.
# Create a Railway Volume and mount it at /data, then set:
DATA_DIR=/data

# Allow all origins (since frontend is served from same Railway URL)
# or restrict to: https://your-app.vercel.app if using separate Vercel frontend
ALLOWED_ORIGINS=*

# System Chromium path inside the Docker container (set in Dockerfile already)
CHROMIUM_PATH=/usr/bin/chromium

# Optional: enrichment API keys
HUNTER_API_KEY=
CLEARBIT_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
